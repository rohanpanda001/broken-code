datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum FaultType {
  LOGIC
  ARCHITECTURE
  DATA_STRUCTURES
}

model Question {
  id          String    @id @default(uuid())
  title       String
  description String
  codeSnippet String
  faultType   FaultType
  attempts    Attempt[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Attempt {
  id              String   @id @default(uuid())
  questionId      String
  question        Question @relation(fields: [questionId], references: [id])
  candidateId     String
  faultyStartLine Int
  faultyEndLine   Int
  critique        String
  score           Int?
  createdAt       DateTime @default(now())
}
