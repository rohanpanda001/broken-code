datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum FaultType {
  LOGIC
  ARCHITECTURE
  DATA_STRUCTURES
}

enum UserRole {
  CANDIDATE
  COMPANY
}

enum AuthProvider {
  GOOGLE
  GITHUB
  EMAIL
}

// ─── Auth / User Models ───────────────────────────────────────────────────────

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  name              String?
  role              UserRole
  hashedPassword    String?      // nullable — not used for SSO accounts
  provider          AuthProvider
  providerAccountId String?      // null for EMAIL provider
  candidate         Candidate?
  company           Company?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Candidate {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts  Attempt[]
  createdAt DateTime  @default(now())
}

model Company {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  createdAt   DateTime @default(now())
}

// ─── Assessment Models ────────────────────────────────────────────────────────

model Question {
  id          String    @id @default(uuid())
  title       String
  description String
  codeSnippet String
  faultType   FaultType
  attempts    Attempt[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Attempt {
  id              String    @id @default(uuid())
  questionId      String
  question        Question  @relation(fields: [questionId], references: [id])
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id])
  faultyStartLine Int
  faultyEndLine   Int
  critique        String
  score           Int?
  createdAt       DateTime  @default(now())
}
